# Mode: LOCAL or AWS
AI_ENGINEERING_MODE=LOCAL

# AWS settings (only used when MODE=AWS)
AWS_REGION=us-east-1
OPENSEARCH_ENDPOINT=https://your-collection.us-east-1.aoss.amazonaws.com
OPENSEARCH_INDEX=chunks_v1
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_GENERATION_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_RERANK_MODEL=cohere.rerank-v3-5:0

# Local settings
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# RAG knobs
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVE_TOP_K=50
RERANK_TOP_K=5
REFUSAL_SCORE_THRESHOLD=0.05
